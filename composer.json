{
  "name": "milpa/http",
  "description": "PSR-15-native routing and middleware contracts for the Milpa PHP framework.",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.3",
    "milpa/core": "^0.2",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpdoc-parser": "^2.3",
    "friendsofphp/php-cs-fixer": "^3.65"
  },
  "autoload": {
    "psr-4": {
      "Milpa\\Http\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Milpa\\Http\\Tests\\": "tests/",
      "Milpa\\Docs\\": "vendor/milpa/core/tools/gen-docs/"
    }
  }
}
